<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- صلاحية الوصول للإنترنت: ضرورية لـ Firebase والذكاء الاصطناعي -->
    <uses-permission android:name="android.permission.INTERNET" />
    <!-- صلاحية الإشعارات: مطلوبة في أندرويد 13 فما فوق لإظهار تنبيهات المنبه -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <!-- صلاحية المنبه الدقيق: لضمان تشغيل التذكيرات في وقتها المحدد بالضبط -->
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM" />
    <!-- صلاحية قراءة الصور: لكي يختار المستخدم صورة للبلاغ من الاستوديو -->
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES" />
    <!-- صلاحية الموقع الجغرافي: لتحديد مكان المشكلة (دقيق وتقريبي) -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.FinaProject">

        <!-- خدمات المزامنة التي تعمل في الخلفية لتحديث البيانات -->
        <service android:name=".data.MyProfileTable.UserSyncService" android:enabled="true" android:exported="true" />
        <service android:name=".data.MyTaskTable.TaskSyncService" android:enabled="true" android:exported="true" />

        <!-- مستقبل التنبيهات: المسؤول عن إظهار الإشعار عند حلول وقت المهمة -->
        <receiver android:name=".TaskReminderReceiver" android:enabled="true" android:exported="false" />

        <!-- تعريف الشاشات المختلفة في التطبيق -->
        <activity android:name=".ReportDetailsActivity" android:exported="false" />
        <activity android:name=".Settings" android:exported="false" />
        <activity android:name=".NewReportScreen" android:exported="false" />
        <activity android:name=".MainActivity" android:exported="false" />
        <activity android:name=".login" android:exported="false" />
        <activity android:name=".signup" android:exported="false" />

        <!-- شاشة البداية (SplashScreen): هي نقطة الانطلاق الوحيدة للتطبيق -->
        <activity android:name=".SplashScreen" android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>

</manifest>
